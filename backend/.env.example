NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/realtime-comm
JWT_SECRET=change-this-to-a-long-random-secret-in-production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
# Optional comma-separated extra browser origins (same credentials rules apply)
CORS_ORIGINS_EXTRA=
# AES-256-GCM: 64 hex chars OR any UTF-8 string of 32+ chars (hashed). Required for production encryptData/decryptData unless you rely on dev-only JWT-derived key (not recommended).
ENCRYPTION_KEY=
# Default 25 MiB
MAX_FILE_SIZE_BYTES=26214400
# Relative to process cwd unless absolute
UPLOAD_DIR=uploads
